# DeepSeek AI API Configuration
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# APIMart image generation API
# Keep this server-only. Never expose it with a NEXT_PUBLIC_ prefix.
APIMART_API_KEY=sk-your-apimart-key-here

# Volcengine Ark multimodal visual tag extraction API
# Keep this server-only.
ARK_API_KEY=your-ark-api-key-here

# Cloudflare R2 storage
# Keep the first three values server-only.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_BASE_URL=https://your-public-bucket-url.example

# Volcengine TTS
# Keep this server-only.
TTS_API_KEY=your-tts-api-key
TTS_API_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
TTS_RESOURCE_ID=seed-tts-2.0
TTS_DEFAULT_SPEAKER=zh_female_tianmeixiaoyuan_uranus_bigtts

# Volcengine STT
# Keep this server-only. If the same key already has STT permission,
# STT_API_KEY may be left empty and the app will fall back to TTS_API_KEY.
STT_API_KEY=
STT_API_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
STT_RESOURCE_ID=volc.bigasr.auc_turbo

# Optional: Enable debug logging for AI service
# Set to "1" or "true" to see detailed request/response logs
AI_DEBUG=0

# Optional: Enable debug logging for image generation / storage flows
# Set to "1" or "true" to see provider task and persistence logs
IMAGE_DEBUG=0

# Optional: Enable debug logging for visual tag extraction
VISION_DEBUG=0

# Optional: Enable debug logging for voice synthesis / recognition
VOICE_DEBUG=0

# Database (optional for local development)
# Leave empty to use local JSON file storage (.data/dev-store.json)
DATABASE_URL=

# App URL (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
